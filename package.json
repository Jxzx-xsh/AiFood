{
  "name": "ai-food",
  "version": "1.0.0",
  "description": "家庭AI食物管家 - Local-First AI Food Management System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "ts-node node_modules/.bin/knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "ts-node node_modules/.bin/knex migrate:rollback --knexfile knexfile.ts",
    "seed": "ts-node node_modules/.bin/knex seed:run --knexfile knexfile.ts"
  },
  "dependencies": {
    "axios": "1.7.9",
    "bull": "4.16.4",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "ioredis": "5.4.2",
    "knex": "3.1.0",
    "pg": "8.13.1",
    "uuid": "11.0.5",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/node": "22.10.5",
    "@types/uuid": "10.0.0",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.7.3"
  }
}
